{
  "version": "1.0.0",
  "push": {
    "autoCreateMissingRecords": true
  },
  "directoryOrder": [
    "schema-info",
    "entities",
    "applications",
    "time-windows",
    "score-band-sets",
    "score-bands",
    "actions"
  ],
  "sqlLogging": {
    "enabled": true,
    "outputDirectory": "./sql_logging",
    "filterPatterns": ["*spCreateAIPromptRun*", "*spUpdateAIPromptRun*"],
    "filterType": "exclude",
    "formatAsMigration": false
  },
  "emitSyncNotes": false
}
