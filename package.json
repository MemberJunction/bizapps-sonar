{
    "name": "bizapps-sonar",
    "version": "1.0.0",
    "license": "ISC",
    "description": "Sonar - Configurable engagement scoring engine built as a MemberJunction Open App",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "prebuild": "node -e \"try { require.resolve('turbo') } catch (e) { console.error('\\n❌ Dependencies not installed. Run: npm install\\n'); process.exit(1); }\"",
        "build": "npm run build:stream",
        "build:stream": "turbo --log-order=stream build",
        "build:generated": "turbo --log-order=stream build --filter=\"@mj-biz-apps/sonar-entities\" --filter=\"@mj-biz-apps/sonar-actions\"",
        "build:packages": "turbo --log-order=stream build --filter=\"@mj-biz-apps/sonar-*\"",
        "build:api": "turbo --log-order=stream build --filter=\"mj_api\"",
        "build:explorer": "turbo --log-order=stream build --filter=\"mj_explorer\"",
        "start": "turbo start --filter=mj_explorer --filter=mj_api",
        "start:api": "turbo start --filter=mj_api",
        "start:explorer": "turbo start --filter=mj_explorer",
        "mj": "npx mj",
        "mj:migrate": "npx mj migrate --schema __mj_BizAppsSonar --dir ./migrations",
        "mj:codegen": "npx mj codegen",
        "install:deps": "npm install",
        "setup": "echo 'Please run: npm run mj:migrate && npm run mj:codegen && npm run build'",
        "change": "changeset",
        "version": "changeset version",
        "commitpush": "node ci/commit_push.mjs",
        "mergemain": "node ci/merge_main.mjs",
        "mergemain:update-lock": "node ci/merge_main_and_update_lock.mjs"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/MemberJunction/bizapps-sonar"
    },
    "packageManager": "npm@10.5.0",
    "devDependencies": {
        "@changesets/cli": "^2.29.8",
        "beasties": "0.3.5",
        "mrmime": "2.0.1",
        "rolldown": "1.0.0-beta.58",
        "rollup": "^4.43.0",
        "simple-git": "^3.31.1",
        "tsc-alias": "^1.8.16",
        "turbo": "^2.7.3",
        "typescript": "^5.9.3",
        "@types/node": "^25.7.0"
    },
    "overrides": {
        "@angular/animations": "21.1.3",
        "@angular/build": "21.1.3",
        "@angular/cli": "21.1.3",
        "@angular/common": "21.1.3",
        "@angular/compiler": "21.1.3",
        "@angular/compiler-cli": "21.1.3",
        "@angular/core": "21.1.3",
        "@angular/forms": "21.1.3",
        "@angular/localize": "21.1.3",
        "@angular/platform-browser": "21.1.3",
        "@angular/platform-browser-dynamic": "21.1.3",
        "@angular/router": "21.1.3",
        "@angular-devkit/build-angular": "21.1.3",
        "@memberjunction/core": "5.40.2",
        "@memberjunction/global": "5.40.2"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=10.0.0"
    }
}
