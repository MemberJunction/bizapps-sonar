# Demo sandbox env overlay — SAFE TO COMMIT (overrides only, NO secrets).
# Loaded on top of the root .env by the `*:demo` npm scripts so the demo stack runs
# against the sandbox DB on its OWN ports — it coexists with the Sonar_Dev stack
# (API 4102 / Explorer 4302); no need to stop anything.
DB_DATABASE=Sonar_Demo
GRAPHQL_PORT=4112
